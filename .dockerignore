# Dependencies (re-installed inside the image)
node_modules
backend/node_modules
frontend/node_modules

# Build outputs
backend/dist
frontend/.next
frontend/out
frontend/.open-next
**/*.tsbuildinfo

# Secrets — never bake into the image
.env
.env.*
!.env.example

# Frontend source is not needed for the backend image
frontend/src
frontend/public

# Git / CI / docs
.git
.github
*.md
!README.md

# Misc
coverage
**/*.log
.DS_Store
