# =============================================================================
# RTP Global VC Screener — monorepo environment (copy to `.env` at repo root)
# =============================================================================
# Backend reads this via backend/src/loadEnv.ts
# Frontend reads this via next.config.ts (NEXT_PUBLIC_* only is exposed to browser)

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
# Local dev only — bypasses login (never in production)
# NEXT_PUBLIC_ALLOW_PREVIEW_MODE=true

# --- Backend server ---
PORT=3001
FRONTEND_URL=http://localhost:3000

# MongoDB (local or Atlas)
MONGODB_URI=mongodb://localhost:27017/vc-screener

# JWT auth (RS256) — generate with: pnpm --filter vc-screener-backend run generate:jwt-keys
JWT_ACCESS_TOKEN_SECRET_PRIVATE=
JWT_ACCESS_TOKEN_SECRET_PUBLIC=
JWT_ACCESS_TOKEN_EXPIRATION_MINUTES=30
REFRESH_TOKEN_EXPIRATION_DAYS=7

# Encrypt per-user API keys at rest (min 32 chars, unique random value)
USER_API_KEYS_ENCRYPTION_SECRET=

# Local dev only — allows unauthenticated API access as preview-user (never in production)
# ALLOW_PREVIEW_MODE=true

# Resend — transactional email (verification, password reset, invites)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
# EMAIL_APP_NAME=RTP Global VC Screener
# EMAIL_LOGO_URL=https://rtp.vc/wp-content/uploads/2023/03/rtp_logo_blackRGB-01.svg

# Required — get yours at console.anthropic.com
ANTHROPIC_API_KEY=
# Model is locked to Claude Haiku in code (claude-haiku-4-5). ANTHROPIC_MODEL is ignored.

# Watchman sanctions screening API (run via Docker)
WATCHMAN_URL=http://localhost:8084

# F17 — web search agent (optional; must be on its own line — do not append other vars)
TAVILY_API_KEY=

# F12 — scheduled portfolio re-screen (optional)
# RESCREEN_SCHEDULER_ENABLED=true
# RESCREEN_INTERVAL_HOURS=168
# DIGEST_WEBHOOK_URL=

# Screening thresholds (optional)
# SCREENING_WATCHMAN_MIN_MATCH=0.80
# SCREENING_FLAGGED_MIN_SCORE=0.95
# SCREENING_REVIEW_MIN_SCORE=0.80
# SCREENING_UBO_PCT_THRESHOLD=25
# SCREENING_OFAC_50_PCT_THRESHOLD=50
# SCREENING_LOG=1

# AUDIT_LOG_RETENTION_DAYS=1825
# DATA_RESIDENCY=

# Rate limits (optional)
# RATE_LIMIT_SCREENER_CHAT_MAX=60
# RATE_LIMIT_ASSISTANT_CHAT_MAX=40

# Cloudflare R2 object storage (optional)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=rtp-global-screener
R2_PUBLIC_URL=

# RAG — document upload & vector search (optional)
OPENAI_API_KEY=
MONGO_VECTOR_SEARCH_ENABLED=true
