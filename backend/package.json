{
  "name": "vc-screener-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && cp -r src/assets dist/assets",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "generate:jwt-keys": "bash scripts/generate-jwt-keys.sh",
    "seed:demo": "tsx scripts/seed-demo-startup.ts",
    "db:reset": "tsx scripts/reset-database.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@aws-sdk/client-s3": "^3.1062.0",
    "@aws-sdk/s3-request-presigner": "^3.1062.0",
    "@upstash/redis": "^1.38.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.1",
    "graphology": "^0.26.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mammoth": "^1.12.0",
    "mongoose": "^8.24.0",
    "multer": "^1.4.5-lts.2",
    "openai": "^6.42.0",
    "pdf-parse": "^2.4.5",
    "resend": "^6.12.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.1",
    "@types/pdf-parse": "^1.1.5",
    "prettier": "^3.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "license": "AGPL-3.0-only"
